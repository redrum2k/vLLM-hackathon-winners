# Copy this to .env and fill in your values.
# Never commit .env to git.

# Slack bot token (xoxb-...)
# Create a bot at https://api.slack.com/apps with scopes:
#   channels:history, channels:read, groups:history, groups:read, users:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# Comma-separated channel names
SLACK_SIGNAL_CHANNELS=general,engineering
SLACK_ARCHIVE_CHANNELS=general,engineering,marketing,hr,finance,product

# Path to your Google service account key JSON file
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json

# Port for the backend server
PORT=3002
