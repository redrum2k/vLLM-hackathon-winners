# Cortex environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ---------------------------------------------------------------------------
# vLLM endpoints
# On Brev: find the public address in the Console under "Using Secure Links"
# ⚠ Replace YOUR_BREV_INSTANCE with your actual hostname before running anything
# ---------------------------------------------------------------------------
VLLM_TEXT_ENDPOINT=https://YOUR_BREV_INSTANCE.brevlab.com:8000/v1
VLLM_VISION_ENDPOINT=https://YOUR_BREV_INSTANCE.brevlab.com:8001/v1

# Local development (if running directly on the Brev instance via SSH):
# VLLM_TEXT_ENDPOINT=http://localhost:8000/v1
# VLLM_VISION_ENDPOINT=http://localhost:8001/v1

# ---------------------------------------------------------------------------
# Model names (must match what vLLM was started with)
# ---------------------------------------------------------------------------
TEXT_MODEL=meta-llama/Llama-3.1-8B-Instruct
VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct

# ---------------------------------------------------------------------------
# HuggingFace (required to download gated models like Llama 3.2 Vision)
# Get your token at: https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HF_TOKEN=hf_YOUR_TOKEN_HERE

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=cortex_corpus

# ---------------------------------------------------------------------------
# Corpus — local mirror synced from Google Drive and Slack
# Subfolders: drive/ and slack/ live under CORPUS_DIR
# ---------------------------------------------------------------------------
CORPUS_DIR=./data/corpus
CORPUS_DRIVE_SUBDIR=drive
CORPUS_SLACK_SUBDIR=slack

# ---------------------------------------------------------------------------
# Embedding model (runs locally — no GPU needed)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
