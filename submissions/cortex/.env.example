# Copy this to .env and fill in your values.

# vLLM endpoint (Brev public URL or localhost:8000)
VLLM_TEXT_ENDPOINT=http://localhost:8000/v1
TEXT_MODEL=/models/llama-3.1-8b-instruct

# ChromaDB
CHROMA_PERSIST_DIR=../../projects/track2-ragas-rerank/chroma_db
CHROMA_COLLECTION=track2_docs

# Embedding model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# RAG server URL (used by Node proxy)
RAG_SERVER=http://localhost:8002
